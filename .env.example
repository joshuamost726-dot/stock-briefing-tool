# Gmail Configuration (for sending briefings)
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASSWORD=your_app_password_here

# API Keys
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
NEWS_API_KEY=your_newsapi_key
# Optional — without this, the "Real vs Noise" verdict falls back to
# rule-based text instead of a Claude-written paragraph (noiseScore.js)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Server
PORT=5000
NODE_ENV=production
